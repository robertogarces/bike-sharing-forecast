# ── MLflow tracking — DagsHub (default) ──────────────────────────────────────
# Get these from https://dagshub.com/<your-username>/<your-repo>/settings/tokens
MLFLOW_TRACKING_URI=https://dagshub.com/<your-dagshub-username>/<your-repo-name>.mlflow
MLFLOW_TRACKING_USERNAME=your-dagshub-username
MLFLOW_TRACKING_PASSWORD=your-dagshub-token

# ── MLflow tracking — Azure ML (optional) ─────────────────────────────────────
# Get this from: az ml workspace show --query mlflow_tracking_uri --output tsv
# Activate with: MLFLOW_TRACKING_URI=$AZURE_MLFLOW_TRACKING_URI python <script>
AZURE_MLFLOW_TRACKING_URI=azureml://<region>.api.azureml.ms/mlflow/v1.0/subscriptions/<subscription-id>/resourceGroups/<resource-group>/providers/Microsoft.MachineLearningServices/workspaces/<workspace-name>
